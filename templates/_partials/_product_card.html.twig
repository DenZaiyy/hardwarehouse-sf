<div class="group relative flex h-full w-full flex-col overflow-hidden rounded-md bg-paragraph p-3 shadow-md transition-all duration-200 md:hover:-translate-y-1 md:hover:shadow-lg">
    <div id="product-like-{{ product.id }}" class="absolute top-2 right-2 z-50 drop-shadow-sm">
        {{ ux_icon('heroicons-solid:heart', {
            class: 'size-7 text-secondary transition-all duration-200 ease-in-out hover:scale-110 hover:text-red-500 hover:animate-wiggle'
        }) }}
    </div>

    <a href="{{ path('product.show', {slug: product.slug}) }}" class="flex flex-1 flex-col no-underline">
        <div class="aspect-square overflow-hidden rounded-md">
            <img
                src="{% if product.thumbnail starts with 'https://' %}{{ product.thumbnail }}{% else %}{{ 'http://localhost:3000/' ~ product.thumbnail }}{% endif %}"
                alt="{{ product.name }} preview"
                loading="lazy"
                class="h-full w-full object-cover object-center transition-transform duration-300 group-hover:scale-[1.03]"
            />
        </div>

        <div class="flex flex-1 flex-col gap-2 pt-3">
            <h2 class="line-clamp-2 min-h-[3.25rem] text-center text-sm font-semibold md:text-base">
                {{ product.name }}
            </h2>

            <p class="line-clamp-3 min-h-[3.75rem] text-center text-sm leading-5 text-gray-700">
                {{ product.shortDescription }}
            </p>

            <p class="mt-auto text-center text-lg font-bold text-black lg:text-xl">
                {{ product.price|format_currency('EUR') }}
            </p>
        </div>
    </a>

    <div class="mt-3">
        <form data-turbo-stream="" action="{{ path('cart.add') }}" method="POST">
            <input type="hidden" name="slug" value="{{ product.slug }}">
            <input type="hidden" name="quantity" value="1">
            <input type="hidden" name="_turbo_stream" value="1">

            <button
                type="submit"
                class="w-full rounded-md bg-primary py-2 text-center text-sm font-title text-paragraph transition-colors hover:bg-primary-dark"
            >
                {{ 'listing.product.button.add_to_cart'|trans }}
            </button>
        </form>
    </div>
</div>

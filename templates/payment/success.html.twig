{% extends 'base.html.twig' %}

{% block title %}Paiement réussi - {{ parent() }}{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto text-center">
        <div class="bg-green-50 border border-green-200 rounded-lg p-8 mb-8">
            <div class="text-green-600 text-6xl mb-4">
                ✓
            </div>
            <h1 class="text-3xl font-bold text-green-800 mb-4">
                Paiement réussi !
            </h1>
            <p class="text-green-700 text-lg">
                {{ message }}
            </p>
        </div>

        <div class="space-y-4">
            <p class="text-gray-600">
                Vous recevrez bientôt un email de confirmation avec les détails de votre commande.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="{{ path('homepage') }}"
                   class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium">
                    Retour à l'accueil
                </a>
                {% if is_granted('ROLE_USER') %}
                    <a href="#"
                       class="border border-gray-300 hover:bg-gray-50 text-gray-700 px-6 py-3 rounded-lg font-medium">
                        Mes commandes
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

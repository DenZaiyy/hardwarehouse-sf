<!DOCTYPE html>
<html lang="{{ app.locale }}" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {% set default_title = "HardWareHouse" %}
    {% set default_description = "seo.description.default"|trans %}

    {# Mise en place des titre #}
    <title>{% block title %}{{ default_title }}{% endblock %}</title>
    <meta property="og:title" content="{% block og_title %}{{ block('title')|default(default_title) }}{% endblock %}">
    <meta name="twitter:title"
          content="{% block twitter_title %}{{ block('title')|default(default_title) }}{% endblock %}">

    <meta name="description" content="{% block meta_description %}{{ default_description }}{% endblock %}">
    <meta property="og:description"
          content="{% block og_description %}{{ block('meta_description')|default(default_description) }}{% endblock %}">
    <meta name="twitter:description"
          content="{% block twitter_description %}{{ block('meta_description')|default(default_description) }}{% endblock %}">

    {# SiteMap #}
    <link rel="sitemap" type="application/xml" title="Sitemap" href="{{ absolute_url('/sitemap.xml') }}">

    <meta name="google-site-verification" content="jQKBB0qiqGkHRkoRXI920Ix1fQmKVCEtsNjPuxMXKnE" />

    {# --- Open Graph --- #}

    <meta property="og:url" content="{% block og_url %}{{ app.request.uri }}{% endblock %}">
    <meta property="og:type" content="{% block og_type %}website{% endblock %}">

    {# --- Twitter Cards --- #}
    <meta name="twitter:card" content="{% block twitter_card %}summary_large_image{% endblock %}">

    {# Les Images #}

    {% set default_image = '/preview/setup.png' %}
    {% if block('img') is defined %}
        {% set img = block('img')|default(default_image) %}
    {% else %}
        {% set img = default_image %}
    {% endif %}

    <meta property="og:image" content="{% block og_image %}{{ img }}{% endblock %}">
    <meta name="twitter:image" content="{% block twitter_image %}{{ img }}{% endblock %}">

    <meta name="robots" content="{% block meta_robots %}index, follow{% endblock %}">
    
    {# Défini la couleur de fond de certain navigateur moderne #}
    <meta name="theme-color" content="{% block theme_color %}#162033{% endblock %}">

    {# Empêche les duplicata d'URL #}
    <link rel="canonical" href="{% block canonical %}{{ app.request.uri }}{% endblock %}">

    {# Fonts Google Exo2 #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Exo+2:ital,wght@0,100..900;1,100..900&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap">

    {# Favicon #}
    <link rel="icon" type="image/png" href="{{ asset('favicon/favicon-96x96.png') }}" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="{{ asset('favicon/favicon.svg') }}" />
    <link rel="shortcut icon" href="{{ asset('favicon/favicon.ico') }}" />
    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('favicon/apple-touch-icon.png') }}" />
    <meta name="apple-mobile-web-app-title" content="HardWareHouse" />
    <link rel="manifest" href="{{ asset('favicon/site.webmanifest') }}" />
    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app', {nonce: csp_nonce()}) }}{% endblock %}
    {% endblock %}
</head>
<body class="flex flex-col min-h-screen relative">
    {% include '_partials/_header.html.twig' %}
    <div id="flash-messages" class="relative">
        {% include '_partials/_flash_messages.html.twig' %}
    </div>
    <div class="flex-1 grow relative">
        <main id="main" class="grow {% if app.current_route != 'homepage' %}p-2 md:p-4{% endif%} md:mx-auto w-full">
            {% block body %}{% endblock %}
        </main>
        <div id="overlay" class="hidden fixed bg-black/50 inset-0 z-40"></div>
    </div>
    {% include '_partials/_footer.html.twig' %}
    <button id="goTop" class="fixed bottom-8 right-8 translate-y-4 bg-secondary rounded-full p-2 text-white shadow-lg inset-shadow-sm cursor-pointer opacity-0 invisible transition-all duration-200">
        {{ ux_icon('heroicons:arrow-up', {class: 'size-6'}) }}
    </button>
</body>
</html>

{% extends 'base.html.twig' %}

{% block title %}Paiement annulé - {{ parent() }}{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="max-w-2xl mx-auto text-center">
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-8 mb-8">
            <div class="text-yellow-600 text-6xl mb-4">
                ⚠️
            </div>
            <h1 class="text-3xl font-bold text-yellow-800 mb-4">
                Paiement annulé
            </h1>
            <p class="text-yellow-700 text-lg">
                {{ message }}
            </p>
        </div>

        <div class="space-y-4">
            <p class="text-gray-600">
                Votre panier est toujours disponible et vous pouvez finaliser votre commande à tout moment.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="{{ path('checkout.index') }}"
                   class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-lg font-medium">
                    Reprendre ma commande
                </a>
                <a href="{{ path('cart.index') }}"
                   class="border border-gray-300 hover:bg-gray-50 text-gray-700 px-6 py-3 rounded-lg font-medium">
                    Voir mon panier
                </a>
                <a href="{{ path('homepage') }}"
                   class="text-gray-500 hover:text-gray-700 px-6 py-3 rounded-lg">
                    Retour à l'accueil
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

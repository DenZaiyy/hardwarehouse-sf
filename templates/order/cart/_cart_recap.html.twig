<div class="flex flex-col gap-4 bg-secondary text-paragraph rounded-lg p-4 w-full">

    <h2 class="font-bold text-lg border-b border-paragraph/20 pb-2">
        {{ 'cart.summary.title'|trans }}
    </h2>

    <div class="hidden md:block text-sm">
        <p class="text-gray-300 mb-3">{{ 'cart.summary.articles'|trans }} ({{ cart|length }})</p>

        <div class="space-y-4 border-b border-paragraph/20 pb-4">
            {% for item in cart %}
                <div class="flex justify-between items-start gap-2">
                    <div class="flex-1 min-w-0">
                        <p class="font-semibold truncate">{{ item.name }}</p>
                        <p class="text-gray-300 text-xs">Qté : {{ item.quantity }}</p>
                        {% if item.promote and item.discount_amount %}
                            <span class="inline-flex items-center gap-1 mt-1 rounded-full bg-red-500/20 border border-red-400/40 px-2 py-0.5 text-xs font-semibold text-red-300">
                                -{{ item.discount_amount|round }}%
                            </span>
                        {% endif %}
                    </div>
                    <div class="text-right shrink-0">
                        <p class="font-semibold">{{ item.effective_ttc|format_currency('EUR') }}</p>
                        {% if item.promote %}
                            <p class="text-gray-400 text-xs line-through">{{ item.price_ttc|format_currency('EUR') }}</p>
                        {% endif %}
                        <p class="text-gray-300 text-xs">{{ item.effective_ht|format_currency('EUR') }} HT/unité</p>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

    <div class="space-y-2 text-sm text-paragraph">
        <div class="flex justify-between">
            <span>Sous-total HT</span>
            <span>{{ totals.subtotal|format_currency('EUR') }}</span>
        </div>
        <div class="flex justify-between">
            <span>TVA ({{ (totals.vat_rate * 100)|round }}%)</span>
            <span>{{ totals.vat_amount|format_currency('EUR') }}</span>
        </div>
        <div class="flex justify-between font-bold text-base border-t border-paragraph/20 pt-2 mt-2">
            <span>Total TTC</span>
            <span>{{ totals.total|format_currency('EUR') }}</span>
        </div>
    </div>

    <a href="{{ path('checkout.index') }}" class="mt-2 w-full block text-center bg-primary hover:bg-primary-dark text-paragraph font-bold text-base px-6 py-3 rounded-lg transition-colors duration-200">
        {{ 'header.cart.checkout.label'|trans }}
        {{ ux_icon('heroicons:arrow-right', {class: 'size-4 inline-block ml-1'}) }}
    </a>

    <form data-turbo-stream="" action="{{ path('cart.clear') }}" method="POST"
          onsubmit="return confirm('Êtes-vous sûr de vouloir vider le panier ?')"
          class="text-center">
        <button type="submit" class="btn-ghost">
            Vider le panier
        </button>
    </form>

</div>

<div class="flex-1 sm:space-y-2 md:space-y-4">
    {% for item in cart %}
        <div class="group relative flex items-center gap-4 {% if not loop.last %}border-b{% endif%} {% if loop.index is even %}bg-secondary/10{% endif%} p-4">
            {% if item.imageUrl %}
                <img src="{{ item.imageUrl }}" alt="{{ item.name }}" loading="lazy" class="w-16 h-16 object-cover rounded">
            {% else %}
                <div class="w-16 h-16 bg-gray-100 rounded flex items-center justify-center text-gray-400 text-xs">
                    No image
                </div>
            {% endif %}

            <div class="flex-1">
                <a href="{{ path('product.show', {slug: item.slug}) }}" class="font-semibold text-sm text-black underline hover:no-underline duration-500 transition-all">{{ item.name }}</a>

                {% if item.promote and item.discount_price %}
                    <div class="flex items-center gap-2">
                        <strong class="text-sm text-black">{{ item.effective_ttc|format_currency('EUR') }}</strong>
                        <span class="text-xs text-gray-400 line-through">{{ item.price_ttc|format_currency('EUR') }}</span>
                        <span class="rounded-full bg-red-100 px-1.5 py-0.5 text-xs font-semibold text-red-600">
                            -{{ item.discount_amount|round }}%
                        </span>
                    </div>
                    <p class="text-gray-400 text-xs">TTC / unité</p>
                {% else %}
                    <p class="text-gray-500 text-sm"><strong>{{ item.price_ttc|format_currency('EUR') }}</strong> TTC / unité</p>
                {% endif %}

                <p class="text-sm">{{ item.category }}</p>
            </div>

            <div class="flex items-center gap-2">
                <form action="{{ path('cart.decrease', {productId: item.productId}) }}" method="POST">
                    <input type="hidden" name="current_qtt" value="{{ item.quantity }}">
                    <button type="submit" class="rounded-md p-2 bg-primary">{{ ux_icon('heroicons:minus', {class: 'size-5'}) }}</button>
                </form>
                <span class="p-2">{{ item.quantity }}</span>
                <form action="{{ path('cart.increase', {productId: item.productId}) }}" method="POST">
                    <input type="hidden" name="current_qtt" value="{{ item.quantity }}">
                    <button type="submit" class="rounded-md p-2 bg-primary">{{ ux_icon('heroicons:plus', {class: 'size-5'}) }}</button>
                </form>
            </div>

            <form action="{{ path('cart.remove', {productId: item.productId}) }}" method="POST" class="md:opacity-0 md:group-hover:opacity-100 absolute top-0 right-0 md:-top-2 md:-right-2 duration-300 transition-opacity">
                <button type="submit" class="bg-red-600 text-white text-sm p-2 rounded-full hover:bg-red-700">
                    {{ ux_icon('heroicons:x-mark', {class: 'size-3'}) }}
                </button>
            </form>
        </div>
    {% endfor %}
</div>

{% extends 'base.html.twig' %}

{% block title %}{{ 'home.title'|trans(domain="title") }} - HardWareHouse{% endblock %}

{% block body %}
    <header class="relative">
        <figure class="relative">
            <img
                class="w-full h-[500px] object-cover"
                src="{{ asset('images/header_50.webp') }}"
                alt="Exemple de configuration PC Haut de gamme"
            >
            <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-primary/20 to-transparent"></div>

            <figcaption class="absolute bottom-20 left-0 right-0 text-center px-4">
                <p class="text-white/70 text-sm font-display uppercase tracking-widest mb-2">Spécialiste composants PC</p>
                <h1 class="text-white text-3xl md:text-5xl font-bold font-title tracking-tight leading-tight mb-4">
                    Construis ton PC<br>
                    <span class="text-blue-300">pièce par pièce.</span>
                </h1>
                <p class="text-white/70 text-base max-w-xl mx-auto">
                    GPU, CPU, cartes mères, RAM, SSD — sélectionnés pour la performance et la compatibilité.
                </p>
            </figcaption>

            <div class="absolute bottom-6 left-0 right-0 flex justify-center gap-3 px-4">
                <a href="{{ path('product.index') }}"
                   class="rounded-full py-2.5 px-6 bg-secondary text-white font-display text-sm font-semibold hover:bg-primary transition-colors no-underline">
                    Explorer les composants
                </a>
                <a href="#builds"
                   class="rounded-full py-2.5 px-6 border border-white/40 text-white font-display text-sm font-semibold hover:bg-white/10 transition-colors no-underline">
                    Voir les builds recommandés
                </a>
            </div>
        </figure>

        <div class="bg-primary text-white">
            <div class="max-w-6xl mx-auto grid grid-cols-3 divide-x divide-white/10">
                <div class="flex flex-col items-center py-4 px-6">
                    <span class="font-title font-bold text-2xl text-blue-300">2 000+</span>
                    <span class="text-white/60 text-xs uppercase tracking-wider mt-0.5">Références en stock</span>
                </div>
                <div class="flex flex-col items-center py-4 px-6">
                    <span class="font-title font-bold text-2xl text-blue-300">24h</span>
                    <span class="text-white/60 text-xs uppercase tracking-wider mt-0.5">Livraison express</span>
                </div>
                <div class="flex flex-col items-center py-4 px-6">
                    <span class="font-title font-bold text-2xl text-blue-300">4.9 ★</span>
                    <span class="text-white/60 text-xs uppercase tracking-wider mt-0.5">Note clients</span>
                </div>
            </div>
        </div>
    </header>

    {# CATÉGORIES #}
    <section class="py-14 px-4 max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-8">
            <div>
                <span class="text-xs font-semibold text-secondary uppercase tracking-widest">Catalogue</span>
                <h2 class="mt-1">Toutes les catégories</h2>
            </div>
            <a href="{{ path('category.index') }}"
               class="text-sm font-semibold text-secondary no-underline hover:underline">
                Voir tout →
            </a>
        </div>

        <div class="grid grid-cols-auto-fit-210 gap-4">
            {% for cat in featured_categories %}
                <a href="{{ path('category.show', { slug: cat.slug }) }}"
                   class="group relative h-44 rounded-[--radius-section] overflow-hidden no-underline
                          shadow-sm hover:shadow-xl transition-shadow duration-300">

                    {% if cat.logo %}
                        <img
                            src="{{ cat.logo }}"
                            alt="{{ cat.name }}"
                            class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                        >
                    {% else %}
                        <div class="absolute inset-0 bg-gradient-to-br from-primary to-secondary/60"></div>
                    {% endif %}

                    {# Dégradé permanent #}
                    <div class="absolute inset-0 bg-gradient-to-t from-primary/90 via-primary/40 to-transparent"></div>

                    {# Flash couleur au hover #}
                    <div class="absolute inset-0 bg-secondary/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

                    <div class="absolute bottom-0 left-0 right-0 p-4">
                        <h3 class="text-white text-sm font-bold font-title leading-tight mb-0.5 drop-shadow">
                            {{ cat.name }}
                        </h3>
                        <p class="text-white/60 text-xs">{{ cat.productsCount }} produits</p>
                    </div>

                    <span class="absolute top-3 right-3 text-white/40 group-hover:text-white
                                 group-hover:translate-x-0.5 group-hover:-translate-y-0.5
                                 transition-all duration-200 text-base leading-none">↗</span>
                </a>
            {% endfor %}
        </div>
    </section>

    {# PRODUITS PHARES #}
    {% if featured_products is defined and featured_products is not empty %}
        <section class="py-14 px-4 bg-slate-50">
            <div class="max-w-6xl mx-auto">
                <div class="flex items-end justify-between mb-8">
                    <div>
                        <span class="text-xs font-semibold text-secondary uppercase tracking-widest">Sélection</span>
                        <h2 class="mt-1">Produits phares</h2>
                    </div>
                    <a href="{{ path('product.index') }}"
                       class="text-sm font-semibold text-secondary no-underline hover:underline">
                        Tout voir →
                    </a>
                </div>

                <div class="grid grid-cols-auto-fit-210 gap-5">
                    {% for product in featured_products %}
                        <article class="bg-white border border-slate-200 rounded-[--radius-section] overflow-hidden
                                    hover:border-secondary hover:shadow-lg transition-all duration-200 flex flex-col">
                            <a href="{{ path('product.show', { slug: product.slug }) }}"
                               class="block overflow-hidden no-underline">
                                {% if product.mainImage %}
                                    <img
                                        src="{{ asset('uploads/products/' ~ product.mainImage) }}"
                                        alt="{{ product.name }}"
                                        class="w-full h-44 object-contain p-4 hover:scale-105 transition-transform duration-300"
                                    >
                                {% else %}
                                    <div class="w-full h-44 bg-slate-100 flex items-center justify-center text-5xl">📦</div>
                                {% endif %}
                            </a>

                            <div class="p-4 flex flex-col flex-1">
                                {% if product.brand %}
                                    <span class="text-xs font-semibold text-secondary uppercase tracking-wider mb-1">
                                    {{ product.brand.name }}
                                </span>
                                {% endif %}

                                <a href="{{ path('product.show', { slug: product.slug }) }}"
                                   class="font-title font-bold text-sm text-slate-800 leading-snug mb-3 hover:text-secondary transition-colors no-underline line-clamp-2">
                                    {{ product.name }}
                                </a>

                                <div class="flex-1"></div>

                                <div class="flex items-center justify-between mt-2">
                                <span class="font-title font-bold text-lg text-primary">
                                    {{ product.price|number_format(2, ',', ' ') }} €
                                </span>
                                    <button type="button"
                                            class="bg-secondary hover:bg-primary text-white rounded-lg px-3 py-2 text-xs font-semibold transition-colors">
                                        + Panier
                                    </button>
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}

    {# BANNIÈRE PROMO #}
    <section class="py-14 px-4 max-w-6xl mx-auto">
        <div class="relative bg-primary rounded-[--radius-section] overflow-hidden px-8 py-12 flex flex-col md:flex-row items-center justify-between gap-8">
            <div class="absolute -right-20 -top-20 w-72 h-72 rounded-full bg-secondary/20 pointer-events-none"></div>
            <div class="absolute -right-4 -bottom-16 w-48 h-48 rounded-full bg-white/5 pointer-events-none"></div>

            <div class="relative z-10">
                <span class="inline-block bg-yellow-400 text-yellow-900 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4">
                    Offre limitée
                </span>
                <h2 class="text-white text-3xl md:text-4xl font-title font-bold tracking-tight leading-tight mb-3">
                    -15% sur tous<br>les processeurs
                </h2>
                <p class="text-white/60 text-sm max-w-md">
                    Du 1<sup>er</sup> au 31 mars. Profite de nos meilleures offres sur les CPU Intel et AMD de dernière génération.
                </p>
            </div>

            <a href="{{ path('category.show', { slug: 'processeurs' }) }}"
               class="relative z-10 flex-shrink-0 rounded-full bg-white text-primary font-display font-bold text-sm px-8 py-3 no-underline hover:bg-blue-50 transition-colors shadow-lg">
                Voir les offres →
            </a>
        </div>
    </section>

    {# POURQUOI NOUS #}
    <section class="py-14 px-4 bg-slate-50">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-10">
                <span class="text-xs font-semibold text-secondary uppercase tracking-widest">Pourquoi HardwareHouse</span>
                <h2 class="mt-1">Ton partenaire hardware de confiance</h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                {% set perks = [
                    {
                        icon: 'ph:lightning-duotone',
                        title: 'Livraison express 24h',
                        desc: 'Commande avant 16h, reçois le lendemain. Expédition depuis notre entrepôt en Alsace.'
                    },
                    {
                        icon: 'ph:magnifying-glass-duotone',
                        title: 'Expertise technique',
                        desc: 'Notre équipe valide la compatibilité de chaque composant. Conseils personnalisés disponibles.'
                    },
                    {
                        icon: 'ph:trophy-duotone',
                        title: 'Meilleur prix garanti',
                        desc: 'On s\'aligne sur n\'importe quel concurrent agréé. Prix compétitifs tous les jours.'
                    },
                    {
                        icon: 'ph:shield-check-duotone',
                        title: 'Garantie constructeur',
                        desc: 'Tous les produits bénéficient de la garantie officielle. SAV réactif et retours simplifiés.'
                    },
                ] %}

                {% for perk in perks %}
                    <div class="bg-white border border-slate-200 rounded-[--radius-section] p-6 flex flex-col gap-4
                                hover:border-secondary hover:shadow-md transition-all duration-200">
                        {# Icône grande dans un carré aux couleurs du thème #}
                        <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-white bg-primary">
                            {{ ux_icon(perk.icon, { class: 'w-7 h-7' }) }}
                        </div>
                        <div>
                            <h3 class="text-slate-800 font-bold mb-1.5">{{ perk.title }}</h3>
                            <p class="text-slate-500 text-xs leading-relaxed">{{ perk.desc }}</p>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>

    {# MARQUES #}
    <section class="py-12 px-4 max-w-6xl mx-auto text-center">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-8">
            Les marques que nous distribuons
        </p>
        <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
            {% for brand in brands %}
                <span class="font-title font-extrabold text-xl text-slate-400 hover:text-primary transition-colors cursor-default tracking-tight">
                    {{ brand.name }}
                </span>
            {% endfor %}
        </div>
    </section>

{% endblock %}

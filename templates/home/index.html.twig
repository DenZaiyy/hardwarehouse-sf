{% extends 'base.html.twig' %}

{% block title %}{{ 'home.title'|trans(domain = 'title') }} - HardWareHouse{% endblock %}

{% block body %}
    <div class="relative overflow-hidden bg-white">
        {# HERO #}
        <section
            data-controller="homepage--home-hero"
            class="relative isolate min-h-[calc(100vh-140px)] bg-primary"
        >
            <div class="absolute inset-0 overflow-hidden pointer-events-none">
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.10),transparent_40%),linear-gradient(to_bottom,rgba(22,32,51,0.25),rgba(22,32,51,0.82))]"></div>
                <div class="absolute inset-0 opacity-[0.07] [background-image:linear-gradient(rgba(255,255,255,.22)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.22)_1px,transparent_1px)] [background-size:48px_48px]"></div>
            </div>

            <div class="relative mx-auto grid min-h-[calc(100vh-140px)] max-w-7xl items-center gap-10 px-4 py-10 md:grid-cols-2 md:px-6 lg:px-8">
                <div class="relative z-10 max-w-2xl">
                    <span
                        data-homepage--home-hero-target="eyebrow"
                        class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/8 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.24em] text-blue-200 backdrop-blur-sm"
                    >
                        <span class="h-1.5 w-1.5 rounded-full bg-blue-300"></span>
                        {{ hero.eyebrow }}
                    </span>

                    <h1
                        data-homepage--home-hero-target="title"
                        class="mt-6 max-w-xl text-4xl font-bold leading-tight text-white sm:text-5xl lg:text-6xl"
                    >
                        {{ hero.title }}
                        <span class="mt-2 block text-blue-300">{{ hero.highlight }}</span>
                    </h1>

                    <p
                        data-homepage--home-hero-target="text"
                        class="mt-6 max-w-xl text-base leading-7 text-white/72 sm:text-lg"
                    >
                        {{ hero.description }}
                    </p>

                    <div
                        data-homepage--home-hero-target="actions"
                        class="mt-8 flex flex-col gap-3 sm:flex-row"
                    >
                        <a
                            href="{{ hero.primary_cta_url }}"
                            class="inline-flex items-center justify-center gap-2 rounded-full bg-secondary px-6 py-3 text-sm font-semibold text-white no-underline shadow-[0_16px_40px_rgba(0,0,0,.24)] transition duration-300 hover:-translate-y-0.5 hover:bg-white hover:text-primary"
                        >
                            {{ hero.primary_cta_label }}
                            <span aria-hidden="true">→</span>
                        </a>

                        <a
                            href="{{ hero.secondary_cta_url }}"
                            class="inline-flex items-center justify-center rounded-full border border-white/18 bg-white/7 px-6 py-3 text-sm font-semibold text-white no-underline backdrop-blur-sm transition duration-300 hover:border-white/35 hover:bg-white/12"
                        >
                            {{ hero.secondary_cta_label }}
                        </a>
                    </div>
                </div>

                <div
                    data-homepage--home-hero-target="visual"
                    class="relative z-10 flex justify-center md:justify-end"
                >
                    <div class="group relative w-full max-w-xl overflow-hidden rounded-[28px] border border-white/12 bg-white/8 p-3 shadow-[0_30px_80px_rgba(0,0,0,.38)] backdrop-blur-sm">
                        <div class="absolute inset-0 rounded-[24px] bg-gradient-to-br from-white/10 via-transparent to-transparent"></div>
                        <div class="absolute inset-x-10 top-0 h-px bg-gradient-to-r from-transparent via-white/50 to-transparent"></div>

                        <figure class="relative overflow-hidden rounded-[22px] border border-white/10 bg-slate-950">
                            <img
                                data-homepage--home-hero-target="image"
                                fetchpriority="high"
                                src="{{ asset(hero.image) }}"
                                alt="Configuration PC premium"
                                class="h-[320px] w-full object-cover sm:h-[420px] lg:h-[520px]"
                            >

                            <div class="absolute inset-0 bg-gradient-to-t from-slate-950/60 via-transparent to-transparent"></div>

                            <div class="absolute left-4 top-4 flex items-center gap-2 rounded-full border border-white/12 bg-slate-950/55 px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.20em] text-white/80 backdrop-blur-sm">
                                <span class="h-2 w-2 rounded-full bg-emerald-400 shadow-[0_0_16px_rgba(52,211,153,.8)]"></span>
                                Build ready
                            </div>

                            <div class="absolute bottom-4 left-4 right-4 grid gap-3 sm:grid-cols-2">
                                <div class="rounded-2xl border border-white/10 bg-slate-950/55 p-4 backdrop-blur-md">
                                    <p class="text-[11px] uppercase tracking-[0.22em] text-white/45">Focus</p>
                                    <p class="mt-2 text-sm font-semibold text-white">Composants triés pour la performance</p>
                                </div>
                                <div class="rounded-2xl border border-white/10 bg-slate-950/55 p-4 backdrop-blur-md">
                                    <p class="text-[11px] uppercase tracking-[0.22em] text-white/45">Objectif</p>
                                    <p class="mt-2 text-sm font-semibold text-white">Une expérience e-commerce plus premium</p>
                                </div>
                            </div>
                        </figure>
                    </div>
                </div>
            </div>

            <div class="relative z-10 border-t border-white/10 bg-slate-950/18 backdrop-blur-sm">
                <div
                    data-homepage--home-hero-target="stats"
                    data-controller="homepage--stats-counter"
                    class="mx-auto grid max-w-7xl grid-cols-1 divide-y divide-white/10 px-4 sm:grid-cols-3 sm:divide-x sm:divide-y-0 md:px-6 lg:px-8"
                >
                    {% for stat in stats %}
                        <div class="flex flex-col items-center px-6 py-5 text-center">
                            <span
                                data-homepage--stats-counter-target="number"
                                data-value="{{ stat.number }}"
                                data-decimals="{{ stat.decimals|default(0) }}"
                                data-suffix="{{ stat.suffix|default('') }}"
                                class="font-title text-3xl font-bold text-blue-300"
                            >
                                0
                            </span>
                            <span class="mt-1 text-xs uppercase tracking-[0.22em] text-white/52">{{ stat.label }}</span>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </section>

        {# CATEGORIES #}
        <section
            id="home-categories"
            data-controller="shared--reveal"
            class="relative mx-auto max-w-7xl px-4 py-18 md:px-6 lg:px-8"
        >
            <div class="mb-8 flex items-end justify-between gap-4">
                <div class="max-w-xl">
                    <span class="text-xs font-semibold uppercase tracking-[0.22em] text-secondary">Catalogue</span>
                    <h2 class="mt-2">Explore les catégories les plus recherchées</h2>
                    <p class="mt-3 text-slate-500">
                        Une entrée rapide vers les univers les plus demandés, avec une présentation plus premium et plus lisible.
                    </p>
                </div>

                <a
                    href="{{ path('category.index') }}"
                    class="hidden text-sm font-semibold text-secondary no-underline transition hover:text-primary md:inline-flex"
                >
                    Voir toutes les catégories →
                </a>
            </div>

            <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
                {% for cat in featured_categories %}
                    <a
                        href="{{ path('category.show', { slug: cat.slug }) }}"
                        data-shared--reveal-target="item"
                        class="group relative min-h-[320px] overflow-hidden rounded-[24px] border border-slate-200/80 bg-slate-950 no-underline shadow-[0_14px_40px_rgba(15,23,42,.08)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_22px_60px_rgba(15,23,42,.16)]"
                    >
                        {% if cat.logo %}
                            <img
                                src="{{ cat.logo }}"
                                alt="{{ cat.name }}"
                                class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-[1.06]"
                            >
                        {% else %}
                            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(255,255,255,.14),transparent_30%),linear-gradient(135deg,rgba(22,32,51,1),rgba(82,111,184,.75))]"></div>
                        {% endif %}

                        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/45 to-transparent"></div>
                        <div class="absolute inset-0 opacity-0 transition duration-300 group-hover:opacity-100 bg-[linear-gradient(135deg,transparent,rgba(255,255,255,.08),transparent)]"></div>

                        <div class="relative z-10 flex h-full flex-col justify-between p-5">
                            <div class="flex items-start justify-between">
                                <span class="rounded-full border border-white/12 bg-white/8 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-white/72 backdrop-blur-sm">
                                    {{ loop.index < 10 ? '0' ~ loop.index : loop.index }}
                                </span>
                                <span class="text-2xl text-white/35 transition duration-300 group-hover:translate-x-1 group-hover:-translate-y-1 group-hover:text-white">↗</span>
                            </div>

                            <div>
                                <h3 class="text-xl font-bold text-white">{{ cat.name }}</h3>
                                <p class="mt-2 text-sm text-white/62">{{ cat.productsCount }} produits</p>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>

            <div class="mt-6 md:hidden">
                <a
                    href="{{ path('category.index') }}"
                    class="inline-flex text-sm font-semibold text-secondary no-underline"
                >
                    Voir toutes les catégories →
                </a>
            </div>
        </section>

        {# PROMO #}
        <section
            data-controller="shared--reveal homepage--promo-motion"
            class="mx-auto max-w-7xl px-4 pb-18 md:px-6 lg:px-8"
        >
            <div class="relative overflow-hidden rounded-[28px] border border-primary/10 bg-primary px-6 py-8 shadow-[0_20px_70px_rgba(15,23,42,.14)] sm:px-8 sm:py-10 lg:px-12">
                <div class="absolute inset-0 opacity-[0.08] [background-image:linear-gradient(rgba(255,255,255,.5)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.5)_1px,transparent_1px)] [background-size:44px_44px]"></div>
                <div data-homepage--promo-motion-target="orbOne" class="absolute -right-14 -top-12 h-44 w-44 rounded-full bg-secondary/30 blur-3xl"></div>
                <div data-homepage--promo-motion-target="orbTwo" class="absolute bottom-0 left-[10%] h-36 w-36 rounded-full bg-white/10 blur-3xl"></div>

                <div class="relative z-10 grid items-center gap-8 lg:grid-cols-[1.4fr_auto]">
                    <div class="max-w-2xl">
                        <span class="inline-flex rounded-full bg-yellow-400 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.22em] text-yellow-950">
                            {{ promo.badge }}
                        </span>

                        <h2 class="mt-4 text-3xl font-bold leading-tight text-white md:text-4xl">
                            {{ promo.title }}
                        </h2>

                        <p class="mt-4 max-w-xl text-sm leading-7 text-white/72 md:text-base">
                            {{ promo.description }}
                        </p>
                    </div>

                    <div class="flex">
                        <a
                            href="{{ promo.cta_url }}"
                            class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-7 py-3.5 text-sm font-semibold text-primary no-underline shadow-[0_14px_34px_rgba(0,0,0,.18)] transition duration-300 hover:-translate-y-0.5 hover:bg-blue-50"
                        >
                            {{ promo.cta_label }}
                            <span aria-hidden="true">→</span>
                        </a>
                    </div>
                </div>
            </div>
        </section>

        {# PRODUITS PHARES #}
        {% if featured_products is defined and featured_products is not empty %}
            <section
                data-controller="shared--reveal"
                class="bg-slate-50/70 py-18"
            >
                <div class="mx-auto max-w-7xl px-4 md:px-6 lg:px-8">
                    <div class="mb-8 flex items-end justify-between gap-4">
                        <div class="max-w-xl">
                            <span class="text-xs font-semibold uppercase tracking-[0.22em] text-secondary">Sélection</span>
                            <h2 class="mt-2">Produits phares</h2>
                            <p class="mt-3 text-slate-500">
                                Une sélection mise en avant pour renforcer la dimension premium et commerciale de la homepage.
                            </p>
                        </div>

                        <a
                            href="{{ path('product.index') }}"
                            class="hidden text-sm font-semibold text-secondary no-underline transition hover:text-primary md:inline-flex"
                        >
                            Tout voir →
                        </a>
                    </div>

                    <div class="grid grid-cols-auto-fit-210 gap-5">
                        {% for product in featured_products %}
                            <article
                                data-shared--reveal-target="item"
                                class="group flex flex-col overflow-hidden rounded-[24px] border border-slate-200 bg-white shadow-[0_12px_32px_rgba(15,23,42,.06)] transition duration-300 hover:-translate-y-1 hover:border-secondary/40 hover:shadow-[0_18px_48px_rgba(15,23,42,.12)]"
                            >
                                <a href="{{ path('product.show', { slug: product.slug }) }}" class="relative block overflow-hidden no-underline">
                                    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(82,111,184,.10),transparent_50%)]"></div>

                                    {% if product.mainImage %}
                                        <img
                                            src="{{ asset('uploads/products/' ~ product.mainImage) }}"
                                            alt="{{ product.name }}"
                                            class="h-52 w-full object-contain p-5 transition duration-500 group-hover:scale-[1.05]"
                                        >
                                    {% else %}
                                        <div class="flex h-52 w-full items-center justify-center bg-slate-100 text-5xl">📦</div>
                                    {% endif %}
                                </a>

                                <div class="flex flex-1 flex-col p-5">
                                    {% if product.brand %}
                                        <span class="text-[11px] font-semibold uppercase tracking-[0.22em] text-secondary">
                                            {{ product.brand.name }}
                                        </span>
                                    {% endif %}

                                    <a
                                        href="{{ path('product.show', { slug: product.slug }) }}"
                                        class="mt-2 line-clamp-2 font-title text-base font-bold leading-snug text-slate-800 no-underline transition hover:text-secondary"
                                    >
                                        {{ product.name }}
                                    </a>

                                    <div class="mt-5 flex-1"></div>

                                    <div class="mt-4 flex items-center justify-between gap-3">
                                        <span class="font-title text-xl font-bold text-primary">
                                            {{ product.price|number_format(2, ',', ' ') }} €
                                        </span>

                                        <button
                                            type="button"
                                            class="rounded-full bg-secondary px-4 py-2 text-xs font-semibold text-white transition duration-300 hover:bg-primary"
                                        >
                                            + Panier
                                        </button>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                    </div>

                    <div class="mt-6 md:hidden">
                        <a
                            href="{{ path('product.index') }}"
                            class="inline-flex text-sm font-semibold text-secondary no-underline"
                        >
                            Tout voir →
                        </a>
                    </div>
                </div>
            </section>
        {% endif %}

        {# PERKS #}
        <section
            data-controller="shared--reveal"
            class="mx-auto max-w-7xl px-4 py-18 md:px-6 lg:px-8"
        >
            <div class="mx-auto max-w-2xl text-center">
                <span class="text-xs font-semibold uppercase tracking-[0.22em] text-secondary">Pourquoi HardWareHouse</span>
                <h2 class="mt-2">Une expérience plus claire, plus technique, plus premium</h2>
                <p class="mt-4 text-slate-500">
                    Ce bloc garde ton angle e-commerce, mais le présente avec une hiérarchie plus premium et plus orientée confiance.
                </p>
            </div>

            <div class="mt-10 grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
                {% for perk in perks %}
                    <article
                        data-shared--reveal-target="item"
                        class="group rounded-[24px] border border-slate-200 bg-white p-6 shadow-[0_12px_30px_rgba(15,23,42,.05)] transition duration-300 hover:-translate-y-1 hover:border-secondary/40 hover:shadow-[0_18px_44px_rgba(15,23,42,.12)]"
                    >
                        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-primary text-white shadow-[0_12px_28px_rgba(22,32,51,.20)] transition duration-300 group-hover:scale-105 group-hover:bg-secondary">
                            {{ ux_icon(perk.icon, { class: 'h-7 w-7' }) }}
                        </div>

                        <h3 class="mt-5 text-lg font-bold text-slate-800">{{ perk.title }}</h3>
                        <p class="mt-3 text-sm leading-7 text-slate-500">{{ perk.desc }}</p>
                    </article>
                {% endfor %}
            </div>
        </section>

        {# MARQUES #}
        <section
            data-controller="shared--reveal homepage--brands-marquee"
            class="border-t border-slate-100 bg-slate-50/70 py-16"
        >
            <div class="mx-auto max-w-7xl px-4 text-center md:px-6 lg:px-8">
                <p class="text-xs font-semibold uppercase tracking-[0.26em] text-slate-400">
                    Les marques que nous distribuons
                </p>

                <div class="mt-8 overflow-hidden">
                    <div
                        data-homepage--brands-marquee-target="track"
                        class="flex min-w-max items-center gap-10 whitespace-nowrap pl-6 will-change-transform"
                    >
                        {% for i in 1..2 %}
                            {% for brand in brands %}
                                <span class="font-title text-2xl font-extrabold tracking-tight text-slate-400 transition duration-300 hover:text-primary">
                                    {{ brand.name }}
                                </span>
                            {% endfor %}
                        {% endfor %}
                    </div>
                </div>
            </div>
        </section>
    </div>
{% endblock %}
